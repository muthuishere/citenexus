{
  "name": "@muthuishere/citenexus-core",
  "version": "0.6.0",
  "description": "CiteNexus TypeScript port — SPEC-PORTS-v1 conformance. Evidence-first RAG: answers only from retrieved evidence, cites verbatim, abstains otherwise.",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/muthuishere/citenexus.git",
    "directory": "js"
  },
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./ffi": {
      "types": "./dist/core/core.d.ts",
      "import": "./dist/core/core.js"
    },
    "./ingest": {
      "types": "./dist/ingest/ingest.d.ts",
      "import": "./dist/ingest/ingest.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "optionalDependencies": {
    "koffi": "^3.1.0"
  }
}
