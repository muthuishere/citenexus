# Local dev/example/integration environment template. Copy to `.env` (gitignored)
# or `example/.env`. These are LOCAL throwaway values — never real secrets.

# --- MinIO (local S3, via compose.yaml) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=19000
MINIO_CONSOLE_PORT=19001
TRUSTRAG_BUCKET=trustrag-local

# --- S3 client config the storage layer reads (S3-compatible → MinIO) ---
TRUSTRAG_S3_ENDPOINT_URL=http://localhost:19000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1

# --- Injected model endpoints for the example (local Ollama, OpenAI-compatible) ---
TRUSTRAG_LLM_BASE_URL=http://localhost:11434/v1
TRUSTRAG_EMBED_BASE_URL=http://localhost:11434/v1
TRUSTRAG_RERANK_BASE_URL=http://localhost:11434/v1
