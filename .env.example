# Local dev/example/integration environment template. Copy to `.env` (gitignored),
# or manage secrets with vsync (`infra/vault/<env>/.env.<env>`). LOCAL throwaway
# values only — never real secrets. Code references keys by NAME, never value.

# ============================================================================
# Default example stack — cheap, hosted, no local infra (Jina + Gemini + LocalFs)
# ============================================================================

# --- Storage: LocalFs (a folder). No S3 endpoint => LocalFs backend. ---
CITENEXUS_BASE_URI=./.citenexus-data

# --- Embedding (Jina, OpenAI-compatible /v1/embeddings) ---
CITENEXUS_EMBED_BASE_URL=https://api.jina.ai/v1
CITENEXUS_EMBED_MODEL=jina-embeddings-v3
CITENEXUS_EMBED_API_KEY=YOUR_JINA_KEY_HERE

# --- Reranker (Jina /v1/rerank; same key) ---
CITENEXUS_RERANK_ENABLED=true
CITENEXUS_RERANK_BASE_URL=https://api.jina.ai/v1
CITENEXUS_RERANK_MODEL=jina-reranker-v2-base-multilingual
CITENEXUS_RERANK_API_KEY=YOUR_JINA_KEY_HERE

# --- Answering LLM (Gemini, OpenAI-compatible endpoint; temperature stays 0) ---
CITENEXUS_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
CITENEXUS_LLM_MODEL=gemini-2.5-flash
CITENEXUS_LLM_API_KEY=YOUR_GEMINI_KEY_HERE

# ============================================================================
# Opt-in all-local stack (uncomment to override the hosted defaults)
# ============================================================================

# --- MinIO (local S3, via compose.yaml: `task local:minio:up`) ---
# CITENEXUS_S3_ENDPOINT_URL=http://localhost:19000
# CITENEXUS_BUCKET=citenexus-local
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# AWS_REGION=us-east-1
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=minioadmin
# MINIO_API_PORT=19000
# MINIO_CONSOLE_PORT=19001

# --- infinity (local embed + rerank, via compose `models` profile) ---
# CITENEXUS_EMBED_BASE_URL=http://localhost:17997/v1
# CITENEXUS_EMBED_MODEL=BAAI/bge-m3
# CITENEXUS_RERANK_BASE_URL=http://localhost:17997
# CITENEXUS_RERANK_MODEL=BAAI/bge-reranker-v2-m3
# INFINITY_PORT=17997

# --- Ollama (local answering LLM, via `task local:ollama:up`) ---
# CITENEXUS_LLM_BASE_URL=http://localhost:11434/v1
# CITENEXUS_LLM_MODEL=qwen2.5
