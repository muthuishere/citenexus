# Example environment — the default is the cheap hosted stack (Jina + Gemini +
# LocalFs). Secrets normally live in the vsync vault (`infra/vault/dev/.env.dev`),
# which `task local:example` loads. Copy this to `example/.env` only if you'd
# rather use a plain file. LOCAL throwaway values only; never real secrets.

# --- Storage: LocalFs (a folder). Set TRUSTRAG_S3_ENDPOINT_URL for MinIO/R2. ---
TRUSTRAG_BASE_URI=./.trustrag-data

# --- Embedding + reranker (Jina, OpenAI-compatible) ---
TRUSTRAG_EMBED_BASE_URL=https://api.jina.ai/v1
TRUSTRAG_EMBED_MODEL=jina-embeddings-v3
TRUSTRAG_EMBED_API_KEY=YOUR_JINA_KEY_HERE
TRUSTRAG_RERANK_ENABLED=true
TRUSTRAG_RERANK_BASE_URL=https://api.jina.ai/v1
TRUSTRAG_RERANK_MODEL=jina-reranker-v2-base-multilingual
TRUSTRAG_RERANK_API_KEY=YOUR_JINA_KEY_HERE

# --- Answering LLM (Gemini, OpenAI-compatible endpoint; temperature stays 0) ---
TRUSTRAG_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
TRUSTRAG_LLM_MODEL=gemini-2.5-flash
TRUSTRAG_LLM_API_KEY=YOUR_GEMINI_KEY_HERE
